# ===== Aplicación =====
APP_ENV=development                # development | production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=info
APP_BASE_URL=https://pulse.tudominio.com

# ===== Base de datos (Oracle Cloud VM) =====
# PostgreSQL 16 + TimescaleDB
DATABASE_URL=postgresql+asyncpg://pulse:pulse_pass@127.0.0.1:5432/pulse
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ===== ScrapegraphAI / LLM =====
# OpenAI-compatible. Puedes usar OpenAI, Together, Groq, o un llama.cpp local.
LLM_PROVIDER=openai               # openai | groq | together | local
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...
LLM_BASE_URL=                     # vacío = default de OpenAI; o http://localhost:11434/v1 para Ollama

# ===== Sitio objetivo =====
TARGET_SITE=statebate.com
TARGET_BASE_URL=https://statebate.com
TARGET_ROOM_LIST_PATH=/list?page={page}
# Respetar robots.txt y ToS. Rate limit conservador.
SCRAPE_REQUEST_DELAY=2.0          # segundos entre requests
SCRAPE_CONCURRENCY=2              # workers paralelos
SCRAPE_USER_AGENT_ROTATION=true
SCRAPE_USE_PROXY=false            # true si tienes pool de proxies

# ===== Pixel / boosting =====
PIXEL_SECRET=change-me-please     # firma HMAC para validar eventos
BOOST_AFFILIATE_ID=               # tu ID de afiliado del programa oficial
BOOST_RECOMMENDER_LOOKBACK_DAYS=14

# ===== GitHub (para CI webhook) =====
GITHUB_TOKEN=
GITHUB_REPO=tu-usuario/statebate-pulse

# ===== Seguridad =====
API_KEY=                          # protege endpoints admin del backend
